{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["jest", "node"],
    "typeRoots": [
      "../../../frontend/node_modules/@types",
      "../../../node_modules/@types"
    ],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "noEmit": true
  },
  "include": ["**/*.ts", "global.d.ts"],
  "exclude": ["node_modules"]
}
