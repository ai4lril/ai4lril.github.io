{
  "$id": "grafana-datasource-provisioning",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grafana Datasource Provisioning Schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "integer",
      "enum": [1]
    },
    "datasources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "access": { "type": "string" },
          "url": { "type": "string" },
          "isDefault": { "type": "boolean" },
          "editable": { "type": "boolean" },
          "jsonData": { "type": "object" },
          "secureJsonData": { "type": "object" }
        },
        "required": ["name", "type", "access", "url"],
        "additionalProperties": true
      }
    }
  },
  "required": ["apiVersion", "datasources"],
  "additionalProperties": false
}
