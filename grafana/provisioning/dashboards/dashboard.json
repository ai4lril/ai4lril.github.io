{
  "title": "ILHRF Linguistic Data Collection Platform",
  "tags": ["voice", "nlp", "data-collection"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "http_requests_total",
          "legendFormat": "Total Requests",
          "refId": "A"
        },
        {
          "expr": "http_requests_errors_total",
          "legendFormat": "Errors",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Response Time",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "http_response_time_average",
          "legendFormat": "Average Response Time (ms)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "User Activity",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "user_activity_total",
          "legendFormat": "User Activity",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Contributions",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "contributions_total",
          "legendFormat": "Contributions",
          "refId": "A"
        }
      ]
    }
  ]
}
