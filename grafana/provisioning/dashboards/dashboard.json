{
  "dashboard": {
    "title": "International Linguistic Heritage Research Foundation Data Collection Platform",
    "tags": [
      "voice",
      "nlp",
      "data-collection"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "uid": "ilhrf-dashboard",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "http_requests_total",
            "legendFormat": "Total",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "expr": "http_requests_errors_total",
            "legendFormat": "Errors",
            "refId": "B",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      },
      {
        "id": 2,
        "title": "Response Time (ms)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "http_response_time_average",
            "legendFormat": "Avg",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      },
      {
        "id": 3,
        "title": "User Activity",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "user_activity_total",
            "legendFormat": "Activity",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      },
      {
        "id": 4,
        "title": "Contributions",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "expr": "contributions_total",
            "legendFormat": "Contributions",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      },
      {
        "id": 5,
        "title": "Queue Jobs (BullMQ)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "targets": [
          {
            "expr": "queue_jobs_waiting",
            "legendFormat": "{{queue}} waiting",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "expr": "queue_jobs_active",
            "legendFormat": "{{queue}} active",
            "refId": "B",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "expr": "queue_jobs_completed",
            "legendFormat": "{{queue}} completed",
            "refId": "C",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "expr": "queue_jobs_failed",
            "legendFormat": "{{queue}} failed",
            "refId": "D",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      },
      {
        "id": 6,
        "title": "Cache Hit Rate (%)",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "targets": [
          {
            "expr": "cache_hit_rate",
            "legendFormat": "Hit Rate",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        }
      },
      {
        "id": 7,
        "title": "Cache Hits / Misses",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        },
        "targets": [
          {
            "expr": "cache_hits_total",
            "legendFormat": "Hits",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "expr": "cache_misses_total",
            "legendFormat": "Misses",
            "refId": "B",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      },
      {
        "id": 8,
        "title": "Cache Keys & Memory (MB)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        },
        "targets": [
          {
            "expr": "cache_keys_total",
            "legendFormat": "Keys",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          },
          {
            "expr": "cache_memory_used_bytes / 1024 / 1024",
            "legendFormat": "Memory MB",
            "refId": "B",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ]
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {}
  }
}